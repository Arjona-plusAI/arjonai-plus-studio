{
    "version": 2,
    "builds": [
        {
            "src": "api/server.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/chat.js",
            "use": "@vercel/node"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "style.css",
            "use": "@vercel/static"
        },
        {
            "src": "script.js",
            "use": "@vercel/static"
        },
        {
            "src": "animations.js",
            "use": "@vercel/static"
        },
        {
            "src": "api-client.js",
            "use": "@vercel/static"
        },
        {
            "src": "install.js",
            "use": "@vercel/static"
        },
        {
            "src": "physics.js",
            "use": "@vercel/static"
        },
        {
            "src": "manifest.json",
            "use": "@vercel/static"
        },
        {
            "src": "sw.js",
            "use": "@vercel/static"
        },
        {
            "src": "ArjonaAI.apk",
            "use": "@vercel/static"
        },
        {
            "src": ".well-known/assetlinks.json",
            "use": "@vercel/static"
        },
        {
            "src": "*.png",
            "use": "@vercel/static"
        },
        {
            "src": "*.jpg",
            "use": "@vercel/static"
        },
        {
            "src": "*.jpeg",
            "use": "@vercel/static"
        },
        {
            "src": "*.svg",
            "use": "@vercel/static"
        },
        {
            "src": "*.ico",
            "use": "@vercel/static"
        },
        {
            "src": "icons/**",
            "use": "@vercel/static"
        },
        {
            "src": "screenshots/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/ArjonaAI.apk",
            "headers": {
                "content-type": "application/vnd.android.package-archive",
                "content-disposition": "attachment; filename=\"ArjonaAI.apk\"",
                "cache-control": "no-cache"
            },
            "dest": "/ArjonaAI.apk"
        },
        {
            "src": "/api/chat",
            "dest": "/api/chat.js"
        },
        {
            "src": "/api/generate",
            "dest": "/api/server.py"
        },
        {
            "src": "/api/health",
            "dest": "/api/server.py"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/server.py"
        },
        {
            "src": "/manifest.json",
            "headers": {
                "cache-control": "no-cache"
            },
            "dest": "/manifest.json"
        },
        {
            "src": "/sw.js",
            "headers": {
                "cache-control": "no-cache"
            },
            "dest": "/sw.js"
        },
        {
            "src": "/.well-known/assetlinks.json",
            "headers": {
                "content-type": "application/json",
                "cache-control": "no-cache"
            },
            "dest": "/.well-known/assetlinks.json"
        },
        {
            "src": "/",
            "headers": {
                "content-type": "text/html; charset=utf-8"
            },
            "dest": "/index.html"
        },
        {
            "src": "/index.html",
            "headers": {
                "content-type": "text/html; charset=utf-8"
            },
            "dest": "/index.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(?!api/)(.*)",
            "headers": {
                "content-type": "text/html; charset=utf-8"
            },
            "dest": "/index.html"
        }
    ]
}
